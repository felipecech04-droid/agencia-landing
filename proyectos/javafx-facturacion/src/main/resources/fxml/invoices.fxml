<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.forja.facturacion.controller.InvoicesController">
    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
    <VBox styleClass="page-header">
        <Label text="Facturas" styleClass="label-title" />
        <Label text="Gestión de facturación" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
    </VBox>

    <HBox styleClass="toolbar">
        <Button text="+ Nueva Factura" styleClass="btn-primary" onAction="#handleNewInvoice" />
        <Button text="Marcar Pagada" styleClass="btn-success" onAction="#handleMarkPaid" />
        <Button text="Exportar TXT" styleClass="btn-secondary" onAction="#handleExport" />
        <Button text="Eliminar" styleClass="btn-danger" onAction="#handleDeleteInvoice" />
    </HBox>

    <TableView fx:id="invoiceTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colInvId" text="Folio" prefWidth="60" />
            <TableColumn fx:id="colInvClient" text="Cliente" prefWidth="200" />
            <TableColumn fx:id="colInvDate" text="Fecha" prefWidth="120" />
            <TableColumn fx:id="colInvSubtotal" text="Subtotal" prefWidth="120" />
            <TableColumn fx:id="colInvIva" text="IVA" prefWidth="100" />
            <TableColumn fx:id="colInvTotal" text="Total" prefWidth="120" />
            <TableColumn fx:id="colInvStatus" text="Estatus" prefWidth="120" />
        </columns>
    </TableView>
</VBox>
