<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.forja.facturacion.controller.ClientsController">
    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>
    <VBox styleClass="page-header">
        <Label text="Clientes" styleClass="label-title" />
        <Label text="Gestión de clientes" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
    </VBox>

    <HBox styleClass="toolbar">
        <Button text="+ Nuevo Cliente" styleClass="btn-primary" onAction="#handleNewClient" />
        <Button text="Editar" styleClass="btn-secondary" onAction="#handleEditClient" />
        <Button text="Eliminar" styleClass="btn-danger" onAction="#handleDeleteClient" />
    </HBox>

    <TableView fx:id="clientTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colName" text="Nombre" prefWidth="200" />
            <TableColumn fx:id="colEmail" text="Email" prefWidth="250" />
            <TableColumn fx:id="colPhone" text="Teléfono" prefWidth="150" />
            <TableColumn fx:id="colAddress" text="Dirección" prefWidth="300" />
        </columns>
    </TableView>
</VBox>
